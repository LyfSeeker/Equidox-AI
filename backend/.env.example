# Equidox AI Backend
PORT=4000
NODE_ENV=development

# PostgreSQL / Supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/equidox

# Stellar
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
GRANT_MANAGER_CONTRACT_ID=
BUILDER_PASSPORT_CONTRACT_ID=
NATIVE_XLM_TOKEN_CONTRACT=

# OpenAI (optional — falls back to mock analysis)
OPENAI_API_KEY=

# GitHub (optional — falls back to mock data)
GITHUB_TOKEN=

# IPFS (optional — falls back to local SHA-256 hash)
IPFS_API_URL=
IPFS_GATEWAY=https://ipfs.io/ipfs/

# x402 premium endpoint
X402_ENABLED=false
X402_PRICE_STROOPS=1000000
