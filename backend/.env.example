# Equidox AI Backend
PORT=4000
NODE_ENV=development

# PostgreSQL / Supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/equidox

# Stellar
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
GRANT_MANAGER_CONTRACT_ID=
BUILDER_PASSPORT_CONTRACT_ID=
NATIVE_XLM_TOKEN_CONTRACT=

# DeepSeek (primary verification engine)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_PRIMARY_PROVIDER=deepseek

# OpenAI (optional fallback if DeepSeek unavailable)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional custom OpenAI-compatible gateway (e.g. Grok / xAI)
# AI_API_KEY=
# AI_BASE_URL=https://api.x.ai/v1
# AI_MODEL=grok-4-0709
# AI_PROVIDER_ID=grok
# AI_PROVIDER_NAME=Grok
# AI_PRIMARY_PROVIDER=grok

# GitHub (optional — raises rate limits; public repos work without token)
GITHUB_TOKEN=

# IPFS (optional — falls back to local SHA-256 hash)
IPFS_API_URL=
IPFS_GATEWAY=https://ipfs.io/ipfs/

# x402 premium endpoint
X402_ENABLED=false
X402_PRICE_STROOPS=1000000
