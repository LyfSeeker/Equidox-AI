# Paste into Railway → backend service → Variables
# Replace ${{ServiceName.VAR}} with your actual Railway service names.

PORT=4000
NODE_ENV=production
RUN_MIGRATIONS=true

# Reference the Railway Postgres plugin (Settings → Variables → Add Reference)
DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_SSL=true

STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
GRANT_MANAGER_CONTRACT_ID=CDCW4WXFK2BM7ND5TYSRLLWLCACZEJUKMXCFRFH6IIDDMFKLKSBNDAAQ
BUILDER_PASSPORT_CONTRACT_ID=CCWQCRUXF2P56F6Z4RZZXPOOQITN55X3QYVXF626PBC4UXTVQRB3WWOL
NATIVE_XLM_TOKEN_CONTRACT=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
FRIENDBOT_URL=https://friendbot.stellar.org

# Kimi / Moonshot (required for AI reviews)
AI_API_KEY=
AI_BASE_URL=https://api.moonshot.ai/v1
AI_MODEL=kimi-k2.6
AI_PROVIDER_ID=kimi
AI_PROVIDER_NAME=Kimi
AI_PRIMARY_PROVIDER=kimi
AI_PIPELINE_MODE=compact
AI_SELF_REVIEW=true
AI_CACHE_REPORTS=true

# Optional failover providers
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# Optional
# GITHUB_TOKEN=
INDEXER_ENABLED=true
INDEXER_POLL_MS=15000
X402_ENABLED=false
IPFS_GATEWAY=https://ipfs.io/ipfs/
