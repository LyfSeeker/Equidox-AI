# Paste into Railway → frontend service → Variables BEFORE the first build.
# These are Docker build ARGs (see frontend/Dockerfile). Rebuild after any change.

PORT=3000
HOSTNAME=0.0.0.0

# Public backend URL (Railway → backend → Settings → Networking → Generate Domain)
NEXT_PUBLIC_API_URL=https://YOUR-BACKEND.up.railway.app

NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_GRANT_MANAGER_CONTRACT_ID=CDCW4WXFK2BM7ND5TYSRLLWLCACZEJUKMXCFRFH6IIDDMFKLKSBNDAAQ
NEXT_PUBLIC_BUILDER_PASSPORT_CONTRACT_ID=CCWQCRUXF2P56F6Z4RZZXPOOQITN55X3QYVXF626PBC4UXTVQRB3WWOL

# Public Keycloak URL (after Keycloak service has a domain)
NEXT_PUBLIC_KEYCLOAK_URL=https://YOUR-KEYCLOAK.up.railway.app
NEXT_PUBLIC_KEYCLOAK_REALM=equidox
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=equidox-frontend
